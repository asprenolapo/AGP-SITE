<header>
  <div class="logo">
    <a href="/"><img src="{{ site.logo }}" alt="{{ site.title }} Torna alla home"></a>
  </div>

  <nav class="nav-links">
    <a class="nav-button" href="/" data-lang-key="header.navHome"></a>
    <a class="nav-button" href="/about-us" data-lang-key="header.navAboutUs"></a>
    <a class="nav-button" href="/future-visions" data-lang-key="header.navFutureVisions"></a>
    <a class="nav-button" href="/research-and-development" data-lang-key="header.navResearchAndDevelopment"></a>
    <a class="nav-button" href="/consultancy" data-lang-key="header.navConsultancy"></a>
    <a class="nav-button" href="/contact-us" data-lang-key="header.navContactUs"></a>
  </nav>
<div class="lang">
  <i class="fa-solid fa-language"></i>
  <div class="lang-switcher" role="group">
    <div class="slider"></div>

    <input class="lang-input" type="radio" name="lang-switcher" id="lang-en" value="en" />
    <label class="lang-btn" for="lang-en" data-lang-key="allLang.enLangName"></label>

    <input class="lang-input" type="radio" name="lang-switcher" id="lang-it" value="it" />
    <label class="lang-btn" for="lang-it" data-lang-key="allLang.itLangName"></label>
  </div>
</div>
  <div class="burger-button">
    <i class="fa-solid fa-bars"></i>
  </div>
</header>

<!-- Overlay scuro dietro l'offcanvas -->
<div class="offcanvas-overlay" id="offcanvas-overlay"></div>

<!-- Offcanvas panel -->
<aside class="offcanvas" id="offcanvas-menu" aria-hidden="true">
  <button class="offcanvas-close" aria-label="Chiudi menu">
    <i class="fa-solid fa-xmark"></i>
  </button>

  <nav class="offcanvas-nav">
    <a class="nav-button" href="/" data-lang-key="header.navHome"></a>
    <a class="nav-button" href="/about-us" data-lang-key="header.navAboutUs"></a>
    <a class="nav-button" href="/future-visions" data-lang-key="header.navFutureVisions"></a>
    <a class="nav-button" href="/research-and-development" data-lang-key="header.navResearchAndDevelopment"></a>
    <a class="nav-button" href="/consultancy" data-lang-key="header.navConsultancy"></a>
    <a class="nav-button" href="/contact-us" data-lang-key="header.navContactUs"></a>
  </nav>
</aside>