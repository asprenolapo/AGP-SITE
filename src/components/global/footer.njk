<footer class="distro-footer">
  <div class="footer-social-row">
    <div class="social-text">
      <span data-lang-key="footer.spanSocial"></span>
    </div>
    <div class="social-links">
      <a href="" target="_blank" rel="noopener" aria-label="Seguici su Facebook">
        <i class="fa-brands fa-facebook"></i>
      </a>
      <a href="" target="_blank" rel="noopener" aria-label="Seguici su X">
        <i class="fa-brands fa-x"></i>
      </a>
      <a href="" target="_blank" rel="noopener" aria-label="Seguici su Instagram">
        <i class="fa-brands fa-instagram"></i>
      </a>
      <a href="" target="_blank" rel="noopener" aria-label="Seguici su LinkedIn">
        <i class="fa-brands fa-linkedin"></i>
      </a>
      <a href="" target="_blank" rel="noopener" aria-label="Guarda i nostri progetti su GitHub">
        <i class="fa-brands fa-github"></i>
      </a>
    </div>
  </div>

  <div class="footer-main-row">
    <div class="footer-col">
      <h6> {{ site.title }} </h6>
      <p> {{ site.description }} </p>
    </div>

    <div class="footer-col">
      <h6 data-lang-key="footer.skills.title"></h6>
      <p data-lang-key="footer.skills.ai"></p>
      <p data-lang-key="footer.skills.systems"></p>
      <p data-lang-key="footer.skills.iot"></p>
      <p data-lang-key="footer.skills.finance"></p>
    </div>

    <div class="footer-col">
      <h6 data-lang-key="footer.navigation.title"></h6>
      <p><a href="/" data-lang-key="footer.navigation.home"></a></p>
      <p><a href="/about-us" data-lang-key="footer.navigation.aboutUs"></a></p>
      <p><a href="/future-visions" data-lang-key="footer.navigation.futureVisions"></a></p>
      <p><a href="/research-and-development" data-lang-key="footer.navigation.reserchAndDevelopment"></a></p>
      <p><a href="/consultancy" data-lang-key="footer.navigation.consultancy"></a></p>
      <p><a href="/contact-us" data-lang-key="footer.navigation.contactUs"></a></p>
    </div>

    <div class="footer-col">
      <h6 data-lang-key="footer.contact.title"></h6>
      <p data-lang-key="footer.contact.avenue"></p>
      <p data-lang-key="footer.contact.email"></p>
      <p data-lang-key="footer.contact.tel"></p>
    </div>
  </div>

  <div class="footer-copyright">
    &copy; {{ site.copyright.year }} {{ site.name }} {{ site.copyright.text }}.
    <strong>{{ site.site_name }}</strong>
  </div>
</footer>
