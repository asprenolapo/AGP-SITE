<section id="contact-forms" class="row">

    <!-- TITOLI E DESCRIZIONI -->
    <div class="col-12 col-md-6">
      <h2 class="section-title">Contattaci</h2>
      <p class="paragraph-contact">
        Hai un progetto in mente o una necessità tecnica da risolvere? <br>
        Siamopronti ad ascoltarti. Sviluppiamo software su misura, incluse soluzioni dedicate a hardware specifici.
      </p>

      <!-- FORM CONTATTACI -->
      <form method="post">
        <fieldset class="border-form">
          
          <label for="name-contact" class="form-label">Nome*</label>
          <input type="text" id="name-contact" name="name" placeholder="Scrivi il tuo Nome" class="form-input" required />
            
          <label for="surname-contact" class="form-label">Cognome*</label>
          <input type="text" id="surname-contact" name="surname" placeholder="Scrivi il tuo Cognome" class="form-input" required/>

          <label for="email-contact" class="form-label">Email*</label>
          <input type="email" id="email-contact" name="email" placeholder="Scrivi la tua Email" class="form-input" required  />

          <label for="tel-contact" class="form-label">Telefono*</label>
          <input type="tel" id="tel-contact" name="tel" placeholder="Telefono Cellulare" class="form-input" required  />

          <label for="messages-contact" class="form-label">Lasciaci un messaggio</label>
          <textarea rows="5" cols="50" maxlength="1500" placeholder="Scrivici Qualcosa" id="messages-contact" name="messages" class="form-input"></textarea>

          <div class="button-group">
            <input type="submit" value="Invia" class="submit-form" />
            <input type="reset" value="Resetta" class="reset-form" />
          </div>
        </fieldset>
      </form>
    </div>
  </section>
  <section id="work-with-us-forms" class="row">
    <div class="col-12 col-md-6">
      <h2 class="section-title">lavora con noi</h2>
      <p class="paragraph-work-with-us">
        Sei uno sviluppatore, un designer o un tecnico con la passione per l'innovazione? <br> 
        Siamo sempre alla ricerca di nuovi talenti da
        inserire nel nostro team. Inviaci la tua candidatura e inserisci Quali sono le Tue Competenze!
      </p>

      <!-- FORM LAVORA CON NOI -->
      <form action="">
        <fieldset class="border-form">
          <label for="name-work-with-us" class="form-label">Nome*</label>
          <input type="text" id="name" name="name-work-with-us" placeholder="Scrivi il tuo Nome" class="form-input" required/>

          <label for="surname-work-with-us" class="form-label">Cognome*</label>
          <input type="text" id="surname" name="surname-work-with-us" placeholder="Scrivi il tuo Cognome" class="form-input" required/>


          <label for="email-work-with-us" class="form-label">Email*</label>
          <input type="email" id="email-work-with-us" name="email" placeholder="Scrivi la tua Email" class="form-input" required/>

          <label for="tel-work-with-us" class="form-label">Telefono*</label>
          <input type="tel" id="tel-work-with-us" name="tel" placeholder="Telefono Cellulare" class="form-input" required/>

          <label for="position" class="form-label">Competenze*</label>
          <select name="position" id="position" class="select-input" required>
            <option value="" selected disabled>Seleziona</option>
            <option value="human_resource">Risorse Umane</option>
            <option value="front_end">Sviluppo Front-End</option>
            <option value="back_end">Sviluppo Back-End</option>
            <option value="marketing">Marketing</option>
          </select>
          <div class="button-group">
            <input type="submit" value="Invia" class="submit-form" />
            <input type="reset" value="Resetta" class="reset-form" />
          </div>
        </fieldset>
      </form>
    </div>
  </section>